		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tsconfig/svelte": "^5.0.8",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.0",
		"svelte-eslint-parser": "^1.8.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.14"
	},
	"dependencies": {
		"@lusc/initiative-tracker-api": "workspace:^",
